    "packages/validator",
    "packages/config",
    "packages/logger",
    "packages/templater",
    "packages/database",
    "packages/storage",
    "packages/produce",
    "packages/consume",
    "packages/http-client",
    "packages/http-server",
    "packages/http-tools",
    "packages/repl-server",
    "packages/console",
    "packages/reverse",
    "packages/analyze"
