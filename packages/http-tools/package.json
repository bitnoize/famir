{
  "name": "@famir/http-tools",
  "type": "module",
  "version": "0.0.3",
  "description": "Famir HTTP tools module",
  "keywords": [
    "famir",
    "fake-mirrors",
    "man-in-the-middle",
    "phishing",
    "reverse-proxy",
    "red-teaming"
  ],
  "author": "Dmitry Krutikov <d.krutikov@gmail.com>",
