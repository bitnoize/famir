    "iconv-lite": "^0.7.2",
    "isbot": "^5.1.39",
    "qs": "^6.15.1",
    "tough-cookie": "^6.0.1",
    "ua-parser-js": "^2.0.9"
  },
  "devDependencies": {
    "@types/content-type": "^1.1.9",
